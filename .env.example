# ============================================
# YouTube Transcript Framework - Environment
# ============================================
# Copy this file to .env and adjust values.
#   cp .env.example .env
#
# .env is in .gitignore and will NOT be committed.
# ============================================

# --- Virtual Environment ---
# Path to external virtual environment (optional).
# Default: .venv (repo-local)
# EXTERNAL_VENV_DIR=/path/to/venv

# --- Flask ---
FLASK_SECRET=change-me-to-a-random-secret

# --- Database ---
YOUTUBE_DB_PATH=youtube_transcripts.db
CHANNELS_DB=channels.db

# --- Output ---
OUT_ROOT=out

# --- YouTube API Keys ---
# Comma-separated format: name=key,name=key
# YOUTUBE_API_KEYS="key1,key2"

# --- NVIDIA API Keys ---
# Comma-separated or numbered variables
# NVIDIA_API_KEYS="key1,key2"
# NVIDIA_API_KEY_1="..."
# NVIDIA_API_KEY_2="..."

# --- Resume / LLM Settings ---
RESUME_BASE_URL="https://integrate.api.nvidia.com/v1"
RESUME_MODEL="z-ai/glm4.7"
RESUME_MAX_TOKENS=16384
RESUME_TIMEOUT=300
RESUME_TEMPERATURE=0.4
RESUME_AGENT_NAMES="agent1,agent2"
RESUME_JOBS_PER_KEY=2

# --- Provider Coordinator ---
# Default: http://127.0.0.1:8788
# YT_PROVIDER_COORDINATOR_URL=http://127.0.0.1:8788
# ADMIN_DATA_TOKEN=your-token
# YT_PROVIDER_CLIENT_SECRET=your-secret
# PROVIDER_ENCRYPTION_KEY=your-key

# --- Provider Blocking Policy ---
RESUME_PROVIDER_PRIORITY="nvidia,groq,cerebras"
RESUME_NVIDIA_NO_BLOCKING=1
RESUME_GROQ_TPD_BLOCKING=1
RESUME_CEREBRAS_TPD_BLOCKING=1
RESUME_OPENROUTER_TPD_BLOCKING=1

# --- Transcript Pacing ---
# YT_TRANSCRIPT_INTER_VIDEO_DELAY_MIN=8
# YT_TRANSCRIPT_INTER_VIDEO_DELAY_MAX=15
# YT_TRANSCRIPT_BACKOFF_CAP_SECONDS=1800
# YT_TRANSCRIPT_MAX_CONSECUTIVE_HARD_BLOCKS=3

# --- Optional ---
# WEBSHARE_API_KEY=
# YOUTUBE_COOKIES_FILE=
# YT_DLP_AUTH_MODE=browser
